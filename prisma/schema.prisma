generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CommoType {
  NavLet
  CivilianLetter
  Orders
  Memorandum
   Others
}

enum Status {
  Completed
  Pending
}

enum RequestStatus {
  Pending
  Approved
  Denied
}

enum Role {
  ADMIN
  USER
}

model Communication {
  id             String          @id @default(cuid())
  lineNumber     Int
  dateDrafted    DateTime
  commoType      CommoType
  subject        String
  recipient      String
  draftedBy      String
  receivedBy     String?
  receivedDate   DateTime?
  status         Status          @default(Pending)
  remarks        String?
  isLocked       Boolean         @default(false)
  lockedBy       String?
  lockedAt       DateTime?
  monthYear      String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  referenceFiles ReferenceFile[]
  editRequests   EditRequest[]

  @@index([monthYear])
  @@index([status])
  @@index([dateDrafted])
}

model ReferenceFile {
  id              String        @id @default(cuid())
  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  fileName        String
  fileUrl         String
  mimeType        String?
  extractedText   String?       @db.Text
  uploadedAt      DateTime      @default(now())

  @@index([communicationId])
}

model EditRequest {
  id              String        @id @default(cuid())
  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  requestedBy     String
  requestedFields Json
  reason          String?
  status          RequestStatus @default(Pending)
  adminNote       String?
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())

  @@index([status])
  @@index([communicationId])
}
